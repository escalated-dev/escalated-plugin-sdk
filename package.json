{
  "name": "@escalated-dev/plugin-sdk",
  "version": "0.1.0",
  "description": "SDK for building Escalated plugins — framework-agnostic, TypeScript-first",
  "type": "module",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "default": "./build/index.js"
    },
    "./types": {
      "types": "./build/types.d.ts",
      "default": "./build/types.js"
    }
  },
  "files": [
    "build/"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --test tests/**/*.test.ts",
    "lint": "eslint . --max-warnings 0",
    "format:check": "prettier --check src/",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "escalated",
    "plugin",
    "sdk",
    "helpdesk"
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.0.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.58.0"
  }
}
